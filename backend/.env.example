# Backend environment variables
# Copy this file to .env and fill in your values

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# A long random secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_me_with_a_strong_random_secret

# Flask settings (keep as-is for local dev)
FLASK_APP=run.py
FLASK_ENV=development
